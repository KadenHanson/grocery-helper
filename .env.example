# Copy to `.env` for local dev. Vite inlines VITE_* vars at build time.
#
# The sync backend URL (your Deno Deploy app). NOT secret — it's safe in the
# public bundle. Without it, the app runs local-only.
VITE_SYNC_URL=https://your-app.deno.dev

# NOTE: there is deliberately no secret here. The shared write secret is entered
# once per device in the app (Settings → Cloud sync) and kept in localStorage,
# so it never ships in the public GitHub Pages bundle.
